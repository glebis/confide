const skills = [
  { id: 'synthetic-session-generator', tag: 'infrastructure',
    title: 'synthetic-session-generator',
    blurb: 'Realistic, fully fictional session transcripts for evals, demos, and training data — the kind of corpus this benchmark runs on. No real client ever needed.',
    alt: 'A fountain pen conjuring two translucent fictional silhouettes rising from a blank page.' },
  { id: 'cbt-session-analysis', tag: 'analysis',
    title: 'cbt-session-analysis',
    blurb: 'One anonymized session in; the client’s cognitive distortions out — named, quoted as evidence, and confidence-rated (Diagnosis-of-Thought structure).',
    alt: 'A magnifying glass over a speech bubble revealing a small tangled knot of thread.' },
  { id: 'multi-session-patterns', tag: 'analysis',
    title: 'multi-session-patterns',
    blurb: 'A client’s whole corpus at once: distortion trends, theme evolution, avoidance candidates, and homework assigned-vs-checked.',
    alt: 'A thread weaving through a row of pages, tracing a gently falling curve.' },
  { id: 'cbt-supervision', tag: 'analysis',
    title: 'cbt-supervision',
    blurb: 'A structural self-check of the therapist’s own session — a 10-element CBT protocol score plus five questions to bring to supervision.',
    alt: 'An empty therapist armchair facing a hand mirror, a small checklist card at its base.' },
  { id: 'act-lens', tag: 'lens',
    title: 'act-lens',
    blurb: 'The same corpus read through ACT psychological flexibility — hexaflex processes, towards/away moves. Exploratory, hypotheses only.',
    alt: 'A six-sided prism bending thin arrows toward a distant flag, one arrow turning away.' },
  { id: 'psychodynamic-lens', tag: 'lens',
    title: 'psychodynamic-lens',
    blurb: 'A cautious psychodynamic reading: the CCRT relationship pattern, coarse defense groups, transference hints. Lowest confidence — deliberately last in line.',
